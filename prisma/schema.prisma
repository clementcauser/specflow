generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  emailVerified     Boolean   @default(false)
  image             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  activeWorkspaceId String?
  accounts          Account[]
  memberships       Member[]
  sessions          Session[]
  specs             Spec[]
}

model Session {
  id                String   @id @default(cuid())
  userId            String
  token             String   @unique
  expiresAt         DateTime
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  activeWorkspaceId String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Workspace {
  id          String               @id @default(cuid())
  name        String
  slug        String               @unique
  logo        String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  type        WorkspaceType
  plan        WorkspacePlan        @default(FREE)
  config      Json                 @default("{}")
  teamSize    WorkspaceTeamSize?
  tagline     String?
  productDescription String?       @db.Text
  techStack   String?
  productStage WorkspaceProductStage?
  specialties  WorkspaceProductType[]
  Client      Client[]
  Epic        Epic[]
  invitations Invitation[]
  members     Member[]
  Project     Project[]
  specs       Spec[]
}

model Member {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String
  createdAt   DateTime      @default(now())
  role        WorkspaceRole @default(MEMBER)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Invitation {
  id          String           @id @default(cuid())
  workspaceId String
  email       String
  expiresAt   DateTime
  inviterId   String
  createdAt   DateTime         @default(now())
  role        WorkspaceRole    @default(MEMBER)
  status      InvitationStatus @default(PENDING)
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
}

model Spec {
  id          String     @id @default(cuid())
  workspaceId String?
  creatorId   String
  title       String
  content     Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  status      SpecStatus @default(DRAFT)
  epicId      String?
  projectId   String?
  prompt      String?
  creator     User       @relation(fields: [creatorId], references: [id])
  Epic        Epic?      @relation(fields: [epicId], references: [id], onDelete: Cascade)
  Project     Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([epicId])
  @@index([projectId])
}

model Client {
  id          String    @id
  workspaceId String
  name        String
  context     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  Workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  Project     Project[]
}

model Epic {
  id          String     @id
  workspaceId String
  title       String
  description String?
  priority    MoSCoW     @default(SHOULD)
  status      EpicStatus @default(OPEN)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime
  Workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  Spec        Spec[]
}

model Project {
  id          String               @id
  workspaceId String
  clientId    String?
  name        String
  description String?
  productType WorkspaceProductType
  stack       String?
  clientName  String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime
  Client      Client?              @relation(fields: [clientId], references: [id])
  Workspace   Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  Spec        Spec[]
}

enum WorkspacePlan {
  FREE
  PRO
  ENTERPRISE
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum WorkspaceProductType {
  ECOMMERCE
  SAAS
  MARKETPLACE
  LANDING_PAGE
  MOBILE
  DESKTOP
  API
  IOT
  AI
  OTHER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum SpecStatus {
  DRAFT
  GENERATING
  DONE
  ERROR
}

enum EpicStatus {
  OPEN
  IN_PROGRESS
  DONE
  ARCHIVED
}

enum MoSCoW {
  MUST
  SHOULD
  COULD
  WONT
}

enum WorkspaceType {
  AGENCY
  PRODUCT
  FREELANCE
}

enum WorkspaceTeamSize {
  SOLO
  SMALL
  MEDIUM
  LARGE
}

enum WorkspaceProductStage {
  PRE_MVP
  MVP
  LIVE
  MATURE
}
